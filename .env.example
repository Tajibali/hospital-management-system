# # MongoDB connection string (use MongoDB Atlas for local dev and production)
# # Get this from Atlas: Database > Connect > Drivers > copy the connection string
# # Make sure to add a database name before the "?" and URL-encode any special characters in your password
# # Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/hospital_db?retryWrites=true&w=majority
# DATABASE_URL="mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/hospital_db?retryWrites=true&w=majority"

# # NextAuth
# # Generate a secret with: openssl rand -base64 32
# NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
# NEXTAUTH_URL="http://localhost:3000"

# # Admin login — this is NOT stored in the database. Set your own email/password here.
# # Whoever knows these two values can log in as Admin at /admin/login.
# ADMIN_EMAIL="admin@opdmirpurmathelo.com"
# ADMIN_PASSWORD="ChangeThisStrongPassword123"
